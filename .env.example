# Server-only. Never expose these in frontend JavaScript.
# Use 32+ random bytes. Signing uses CURRENT only; verification accepts CURRENT and PREVIOUS.
SCORE_SECRET_CURRENT=replace-with-32-plus-random-bytes
SCORE_SECRET_PREVIOUS=

# Optional Upstash Redis REST settings for serverless-safe rate limits and replay checks.
# Leave empty for local/dev in-memory fallback.
REDIS_URL=
REDIS_TOKEN=

# Public AdSense publisher id. This is not a secret.
# The production HTML currently loads ca-pub-5739509391465177 directly.
VITE_ADSENSE_CLIENT_ID=ca-pub-5739509391465177

# Optional deployment metadata.
NODE_ENV=production
